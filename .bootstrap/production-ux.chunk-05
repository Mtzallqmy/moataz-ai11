+  .bottom-nav { position: fixed; inset-inline: 8px; inset-block-end: 8px; z-index: 18; display: grid; grid-template-columns: repeat(5, 1fr); padding: 5px; border: 1px solid var(--border); border-radius: 18px; background: rgba(9, 14, 26, 0.91); backdrop-filter: blur(22px); box-shadow: var(--shadow); }
+  :root[data-theme="light"] .bottom-nav { background: rgba(255, 255, 255, 0.92); }
+  .bottom-nav button { min-width: 0; min-height: 52px; display: grid; place-items: center; gap: 1px; padding: 4px; color: var(--muted); background: transparent; border: 0; box-shadow: none; }
+  .bottom-nav button.active { color: var(--text); background: rgba(124, 92, 255, 0.13); }
