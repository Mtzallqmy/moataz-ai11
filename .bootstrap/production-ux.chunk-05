+  .sidebar { inset-block: 0; inset-inline-start: 0; width: min(84vw, 310px); height: 100vh; border-radius: 0 22px 22px 0; transform: translateX(-105%); transition: transform 180ms ease; }
+  [dir="rtl"] .sidebar { border-radius: 22px 0 0 22px; transform: translateX(105%); }
