+  .settings-grid { grid-template-columns: 1fr; }
 }
-@media(max-width: 560px) {
-  main { padding: 10px; gap: 10px; }
-  .tile, section, .hero { border-radius: 20px; padding: 16px; }
-  .msg { max-width: 96%; }
-  .composer { align-items: end; }
+
+@media (max-width: 620px) {
+  .main-content { padding-inline: 9px; }
+  .page-header { display: grid; gap: 12px; }
+  .page-header .page-actions, .page-header .page-actions button { width: 100%; }
+  .stats-grid, .form-grid, .conversation-toolbar { grid-template-columns: 1fr; }
+  .span-2 { grid-column: auto; }
+  .form-actions { display: grid; grid-template-columns: 1fr; }
+  .resource-card { align-items: stretch; flex-direction: column; }
+  .resource-actions { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); }
+  .resource-actions button:first-child { grid-column: 1 / -1; }
+  .msg { width: 94%; }
+  .composer { grid-template-columns: 1fr; }
+  .composer button { width: 100%; }
+  .identity-card dl, .definition-list { grid-template-columns: 1fr; }
+  .identity-card dd, .definition-list dd { margin-bottom: 8px; }
   .terminal-input { grid-template-columns: 1fr; }
 }
