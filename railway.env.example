NODE_ENV=production
APP_URL=https://YOUR-SERVICE.up.railway.app
CORS_ORIGIN=https://YOUR-SERVICE.up.railway.app
TRUST_PROXY=1

JWT_SECRET=REPLACE_WITH_RANDOM_32_PLUS_CHARACTERS
ENCRYPTION_KEY=REPLACE_WITH_DIFFERENT_RANDOM_32_PLUS_CHARACTERS
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres
DATABASE_SSL_MODE=require
DATABASE_SSL_CA=
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_CONNECT_ATTEMPTS=5

DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=REPLACE_WITH_STRONG_12_PLUS_CHARACTER_PASSWORD

WORKSPACE_DIR=/app/workspace
ALLOW_SHELL=false
ALLOW_LOCAL_AI_PROVIDERS=false
SHELL_SANDBOX_MODE=disabled
TELEGRAM_POLLING=false
LOG_LEVEL=info
