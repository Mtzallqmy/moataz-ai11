# Railway production template for Mtzallqmy/moataz-ai11
# Add these as Railway Variables. Never commit real secret values.

NODE_ENV=production
APP_URL=https://moataz-ai11-production.up.railway.app
CORS_ORIGIN=https://moataz-ai11-production.up.railway.app
TRUST_PROXY=1

JWT_SECRET=replace_with_a_random_value_at_least_32_characters
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
ENCRYPTION_KEY=replace_with_a_different_random_value_at_least_32_characters

DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres
DATABASE_SSL_MODE=require

DEFAULT_ADMIN_EMAIL=admin@moataz.ai
DEFAULT_ADMIN_PASSWORD=replace_with_a_strong_password_of_12_or_more_characters

WORKSPACE_DIR=/app/workspace
ALLOW_SHELL=false
SHELL_SANDBOX_MODE=disabled
TELEGRAM_POLLING=false
LOG_LEVEL=info
