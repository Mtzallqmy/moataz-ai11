# Moataz AI environment variable names.
# Values are intentionally blank. Configure them manually in Railway Variables
# or in a local .env file. The application does not generate production
# credentials, database URLs, or administrator accounts.

NODE_ENV=
PORT=
APP_URL=
CORS_ORIGIN=
TRUST_PROXY=

JWT_SECRET=
JWT_ACCESS_TTL_SECONDS=
REFRESH_TOKEN_TTL_SECONDS=
ENCRYPTION_KEY=

DATABASE_URL=
DATABASE_SSL_MODE=
WORKSPACE_DIR=

DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=

ALLOW_SHELL=
SHELL_SANDBOX_MODE=
TELEGRAM_POLLING=

MAX_MESSAGE_CHARS=
MAX_CONTEXT_MESSAGES=
MAX_TOOL_ITERATIONS=
MAX_FILE_BYTES=
MAX_LIST_ENTRIES=
MAX_LIST_DEPTH=
MAX_TOOL_OUTPUT_BYTES=
LLM_TIMEOUT_MS=
WEB_FETCH_TIMEOUT_MS=
MAX_WEB_FETCH_BYTES=
SANDBOX_TIMEOUT_MS=

WS_TICKET_TTL_SECONDS=
TERMINAL_MAX_CONNECTIONS_PER_USER=
TERMINAL_IDLE_TIMEOUT_MS=
TERMINAL_MAX_SESSION_MS=
TERMINAL_MAX_INPUT_BYTES=

LOG_LEVEL=
