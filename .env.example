# Moataz AI environment template
# Copy to .env for local development. Never commit the real .env file.

NODE_ENV=development
PORT=8080
APP_URL=http://localhost:5173

# Production requires at least 32 characters for both secrets.
JWT_SECRET=replace_with_a_random_value_at_least_32_characters
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
ENCRYPTION_KEY=replace_with_a_different_random_value_at_least_32_characters

# Local compatibility database for phases 0-1:
DATABASE_URL=file:./data/moataz.db
# PostgreSQL/Supabase example (use the pooler URL for server deployments):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres
DATABASE_SSL_MODE=disable

WORKSPACE_DIR=./workspace

# The in-process shell is deliberately unavailable in production. The only
# phase-1 opt-in is for trusted local development; it is NOT a sandbox.
ALLOW_SHELL=false
SHELL_SANDBOX_MODE=disabled

DEFAULT_ADMIN_EMAIL=admin@moataz.ai
DEFAULT_ADMIN_PASSWORD=replace_with_a_strong_initial_admin_password

TELEGRAM_POLLING=false

# Comma-separated allowlist. In production, an empty value falls back to the
# origin of APP_URL; it never enables wildcard CORS.
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=false

MAX_MESSAGE_CHARS=4000
MAX_CONTEXT_MESSAGES=20
MAX_TOOL_ITERATIONS=3
MAX_FILE_BYTES=1048576
MAX_LIST_ENTRIES=1000
MAX_LIST_DEPTH=8
MAX_TOOL_OUTPUT_BYTES=262144
LLM_TIMEOUT_MS=60000

WS_TICKET_TTL_SECONDS=45
TERMINAL_MAX_CONNECTIONS_PER_USER=1
TERMINAL_IDLE_TIMEOUT_MS=300000
TERMINAL_MAX_SESSION_MS=1800000
TERMINAL_MAX_INPUT_BYTES=8192

LOG_LEVEL=info
